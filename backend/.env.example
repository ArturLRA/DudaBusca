# Neon PostgreSQL (obtenha em https://neon.tech)
DATABASE_URL=postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/dudabusca?sslmode=require

# Google Cloud Vision API
# Crie uma service account em https://console.cloud.google.com
# e baixe o JSON de credenciais
GOOGLE_APPLICATION_CREDENTIALS=./credentials/google-vision.json

# Gemini API (obtenha em https://aistudio.google.com)
GEMINI_API_KEY=AIza...

# Servidor
PORT=3000
NODE_ENV=development

# Confiança mínima para aceitar uma leitura (0-100)
MIN_CONFIDENCE=75
