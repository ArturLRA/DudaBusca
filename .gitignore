# Learn more https://docs.github.com/en/get-started/getting-started-with-git/ignoring-files

# ── Dependencies ──────────────────────────────────────────────────────────────
node_modules/
backend/node_modules/

# ── Environment (NEVER commit real .env) ─────────────────────────────────────
.env
.env.local
.env.*.local
!.env.example
!backend/.env.example

# ── Google Cloud / credentials (NEVER commit) ─────────────────────────────────
credentials/
*.json.key
google-service-account.json
*-service-account*.json

# ── Expo ─────────────────────────────────────────────────────────────────────
.expo/
dist/
web-build/
expo-env.d.ts

# ── EAS build artifacts ───────────────────────────────────────────────────────
*.aab
*.apk
*.ipa
*.keystore

# ── Backend build ─────────────────────────────────────────────────────────────
backend/dist/
backend/drizzle/

# ── Native ───────────────────────────────────────────────────────────────────
.kotlin/
*.orig.*
*.jks
*.p8
*.p12
*.key
*.mobileprovision
*.pem
/ios
/android

# ── Metro ────────────────────────────────────────────────────────────────────
.metro-health-check*

# ── Logs ─────────────────────────────────────────────────────────────────────
npm-debug.*
yarn-debug.*
yarn-error.*
*.log

# ── OS ───────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── Claude Code ──────────────────────────────────────────────────────────────
.claude/

# ── TypeScript ───────────────────────────────────────────────────────────────
*.tsbuildinfo

# ── Test ─────────────────────────────────────────────────────────────────────
coverage/
